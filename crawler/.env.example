# Supabase 연결 (Project Settings > API)
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
# service_role 키 (절대 프론트/공개 저장소에 노출 금지 — RLS 우회 권한)
SUPABASE_SERVICE_KEY=eyJhbGciOi...service_role...

# 옵션
# FORCE=1          # 주말/휴장 가드 무시
# DRY=1            # stage1 수집만, DB 적재 안 함
# NO_DETAIL=1      # stage2(국내 종목별 상세) 생략
# NO_US=1          # stage3(미국 ETF) 생략
# NO_YAHOO=1       # 미국 구성종목·섹터·보수(Yahoo) 보강 생략
# DETAIL_LIMIT=20  # 국내 상세 N개만(테스트용)
